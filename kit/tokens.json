{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "AO Design System tokens, DTCG format. Use to wire Figma variables or share with engineering for parity validation.",
  "$version": "2.0.0",

  "color": {
    "gray": {
      "10":  { "$value": "#f8f9fa", "$type": "color", "$description": "Page background, subtle dividers" },
      "20":  { "$value": "#f0f2f2", "$type": "color", "$description": "Neutral surface backgrounds" },
      "30":  { "$value": "#e2e7e8", "$type": "color", "$description": "Hover states on neutral surfaces" },
      "40":  { "$value": "#d6dddf", "$type": "color", "$description": "Default borders, dividers" },
      "50":  { "$value": "#c1c7c9", "$type": "color", "$description": "Disabled borders" },
      "60":  { "$value": "#abb1b4", "$type": "color", "$description": "Placeholder text, muted icons" },
      "70":  { "$value": "#727677", "$type": "color", "$description": "Secondary icons, inactive labels" },
      "80":  { "$value": "#595d5e", "$type": "color", "$description": "Tertiary text" },
      "90":  { "$value": "#3f4344", "$type": "color", "$description": "Secondary text, subdued headings" },
      "100": { "$value": "#212121", "$type": "color", "$description": "Primary body text on light backgrounds" }
    },

    "brand": {
      "primary-base":  { "$value": "#12c35a", "$type": "color", "$description": "Brand accent, glow" },
      "primary-light": { "$value": "#befcc8", "$type": "color", "$description": "Light green tints, success backgrounds" },
      "primary-dark":  { "$value": "#02422b", "$type": "color", "$description": "Dark green text on light green" }
    },

    "type": {
      "primary":   { "$value": "#011f44", "$type": "color", "$description": "Main headings, display text" },
      "secondary": { "$value": "#212121", "$type": "color", "$description": "Body text, default UI labels" },
      "tertiary":  { "$value": "#595d5e", "$type": "color", "$description": "Supporting text, captions, helper copy" }
    },

    "action": {
      "primary": {
        "base":     { "$value": "#00893e", "$type": "color" },
        "hover":    { "$value": "#00560b", "$type": "color" },
        "focus":    { "$value": "#00893e", "$type": "color" },
        "active":   { "$value": "#02422b", "$type": "color" },
        "contrast": { "$value": "#ffffff", "$type": "color" },
        "glow":     { "$value": "#12c35a", "$type": "color" }
      },
      "secondary": {
        "base":     { "$value": "#0564c2", "$type": "color" },
        "hover":    { "$value": "#00318f", "$type": "color" },
        "focus":    { "$value": "#0564c2", "$type": "color" },
        "active":   { "$value": "#001876", "$type": "color" },
        "contrast": { "$value": "#ffffff", "$type": "color" },
        "glow":     { "$value": "#40a1f8", "$type": "color" }
      },
      "light": {
        "base":     { "$value": "#ffffff", "$type": "color" },
        "contrast": { "$value": "#011f44", "$type": "color" },
        "glow":     { "$value": "#40a1f8", "$type": "color" }
      },
      "dark": {
        "base":     { "$value": "#011f44", "$type": "color" },
        "contrast": { "$value": "#ffffff", "$type": "color" },
        "glow":     { "$value": "#40a1f8", "$type": "color" }
      },
      "inactive": {
        "base":     { "$value": "#727677", "$type": "color" },
        "contrast": { "$value": "#ffffff", "$type": "color" }
      }
    },

    "ui": {
      "core":      { "base": { "$value": "#ffffff", "$type": "color" }, "contrast": { "$value": "#212121", "$type": "color" }, "accent": { "$value": "#d6dddf", "$type": "color" } },
      "neutral":   { "base": { "$value": "#f0f2f2", "$type": "color" }, "contrast": { "$value": "#212121", "$type": "color" }, "accent": { "$value": "#abb1b4", "$type": "color" } },
      "highlight": { "base": { "$value": "#edf2ff", "$type": "color" }, "contrast": { "$value": "#00318f", "$type": "color" }, "accent": { "$value": "#00318f", "$type": "color" } },
      "success":   { "base": { "$value": "#f4fce3", "$type": "color" }, "contrast": { "$value": "#02422b", "$type": "color" }, "accent": { "$value": "#00893e", "$type": "color" } },
      "warning":   { "base": { "$value": "#fff4e6", "$type": "color" }, "contrast": { "$value": "#ad5a00", "$type": "color" }, "accent": { "$value": "#ff9e36", "$type": "color" } },
      "error":     { "base": { "$value": "#fff0f6", "$type": "color" }, "contrast": { "$value": "#b50016", "$type": "color" }, "accent": { "$value": "#b50016", "$type": "color" } },
      "light":     { "base": { "$value": "#ffffff", "$type": "color" }, "contrast": { "$value": "#011f44", "$type": "color" }, "accent": { "$value": "#ffffff", "$type": "color" } },
      "dark":      { "base": { "$value": "#011f44", "$type": "color" }, "contrast": { "$value": "#ffffff", "$type": "color" }, "accent": { "$value": "#011f44", "$type": "color" } }
    },

    "palette": {
      "$description": "Decorative only. Never use for functional UI states.",
      "bread":  { "$value": "#ffe3c2", "$type": "color" },
      "toast":  { "$value": "#ffa878", "$type": "color" },
      "jam":    { "$value": "#422439", "$type": "color" },
      "simmer": { "$value": "#ffd8d2", "$type": "color" },
      "heat":   { "$value": "#f96155", "$type": "color" },
      "burn":   { "$value": "#60222f", "$type": "color" },
      "steam":  { "$value": "#c8d1ff", "$type": "color" },
      "ice":    { "$value": "#4a6dce", "$type": "color" },
      "water":  { "$value": "#011f44", "$type": "color" }
    },

    "shadow-overlay": { "$value": "#011630", "$type": "color", "$description": "Scrim overlay base" }
  },

  "spacing": {
    "1":  { "$value": "0.25rem", "$type": "dimension", "$description": "4px"  },
    "2":  { "$value": "0.5rem",  "$type": "dimension", "$description": "8px"  },
    "3":  { "$value": "0.75rem", "$type": "dimension", "$description": "12px" },
    "4":  { "$value": "1rem",    "$type": "dimension", "$description": "16px" },
    "5":  { "$value": "1.25rem", "$type": "dimension", "$description": "20px" },
    "6":  { "$value": "1.5rem",  "$type": "dimension", "$description": "24px" },
    "8":  { "$value": "2rem",    "$type": "dimension", "$description": "32px" },
    "10": { "$value": "2.5rem",  "$type": "dimension", "$description": "40px" },
    "12": { "$value": "3rem",    "$type": "dimension", "$description": "48px" },
    "14": { "$value": "3.5rem",  "$type": "dimension", "$description": "56px" },
    "16": { "$value": "4rem",    "$type": "dimension", "$description": "64px" }
  },

  "radius": {
    "xs":  { "$value": "4px",  "$type": "dimension", "$description": "Tags, chips, small badges" },
    "sm":  { "$value": "8px",  "$type": "dimension", "$description": "Buttons, inputs, select"   },
    "md":  { "$value": "16px", "$type": "dimension", "$description": "Cards, modals, drawers"    },
    "xl":  { "$value": "24px", "$type": "dimension", "$description": "Large surface containers"  },
    "2xl": { "$value": "40px", "$type": "dimension", "$description": "Pills, full-round tags"    }
  },

  "shadow": {
    "default": { "$value": "0 1px 3px rgba(1,22,48,0.08), 0 1px 2px rgba(1,22,48,0.05)", "$type": "shadow", "$description": "Cards, default surfaces" },
    "md":      { "$value": "0 4px 8px rgba(1,22,48,0.10), 0 2px 4px rgba(1,22,48,0.06)", "$type": "shadow", "$description": "Raised cards, dropdowns"   },
    "lg":      { "$value": "0 10px 28px rgba(1,22,48,0.13), 0 4px 8px rgba(1,22,48,0.07)", "$type": "shadow", "$description": "Modals, drawers"          },
    "xl":      { "$value": "0 20px 48px rgba(1,22,48,0.18), 0 8px 16px rgba(1,22,48,0.10)", "$type": "shadow", "$description": "Tooltips"                 }
  },

  "typography": {
    "family": {
      "smiley":  { "$value": "SmileyFace, Georgia, serif",         "$type": "fontFamily", "$description": "Headings + all button labels (CTAs)" },
      "smiley-headline": { "$value": "SmileyFace-Headline, Georgia, serif", "$type": "fontFamily", "$description": "Hero headlines, campaign display" },
      "inter":   { "$value": "Inter, ui-sans-serif, system-ui, sans-serif", "$type": "fontFamily", "$description": "Body, UI labels, form fields"   }
    },
    "size": {
      "display-headline": { "$value": "3rem",     "$type": "dimension" },
      "display-lg":       { "$value": "2.5rem",   "$type": "dimension" },
      "display":          { "$value": "2rem",     "$type": "dimension" },
      "title-lg":         { "$value": "1.375rem", "$type": "dimension" },
      "title":            { "$value": "1.125rem", "$type": "dimension" },
      "title-sm":         { "$value": "1rem",     "$type": "dimension" },
      "cta":              { "$value": "1rem",     "$type": "dimension" },
      "body":             { "$value": "1rem",     "$type": "dimension" },
      "body-sm":          { "$value": "0.875rem", "$type": "dimension" },
      "caption":          { "$value": "0.75rem",  "$type": "dimension" }
    }
  },

  "breakpoint": {
    "xs": { "$value": "360px",  "$type": "dimension", "$description": "Small phones"     },
    "sm": { "$value": "544px",  "$type": "dimension", "$description": "Large phones"     },
    "md": { "$value": "768px",  "$type": "dimension", "$description": "Tablets"          },
    "lg": { "$value": "990px",  "$type": "dimension", "$description": "Small desktop"    },
    "xl": { "$value": "1200px", "$type": "dimension", "$description": "Large desktop"    }
  }
}
